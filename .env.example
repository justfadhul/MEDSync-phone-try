# =============================================================================
# MedSync — environment variable reference
# -----------------------------------------------------------------------------
# NAMES ONLY. Never commit real values to this file. Copy to `.env.local`
# (web) or the appropriate app-level env file and fill values there.
# Every variable the platform reads MUST be declared here.
# =============================================================================

# --- Supabase (NEW project — do NOT reuse any existing MedSync project) ------
# Public, safe to expose to the browser/mobile bundle:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. MUST NEVER be imported into any client bundle:
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Database (Drizzle / migrations) -----------------------------------------
# Server-only connection string used by migrations and server code:
DATABASE_URL=

# --- Application-level PHI encryption (Gate 0.5, AES-256-GCM) -----------------
# 32-byte key, base64-encoded. Server-only. Rotatable — see encryption docs.
PHI_ENCRYPTION_KEY=
# Comma-separated retired keys kept for decrypting historical rows during rotation.
PHI_ENCRYPTION_KEY_PREVIOUS=
