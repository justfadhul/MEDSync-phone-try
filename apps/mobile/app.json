{
  "expo": {
    "name": "MedSync",
    "slug": "medsync",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "medsync",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.medsync.app"
    },
    "android": {
      "package": "com.medsync.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
