# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# monorepo tooling
.turbo/

# testing
coverage/

# next.js
.next/
out/

# production build output
build/
dist/

# expo / react-native
.expo/
.expo-shared/
*.orig.*
web-build/

# native
*.apk
*.ipa
*.keystore

# supabase local
supabase/.branches/
supabase/.temp/

# misc
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit real values. Only .env.example (names only) is tracked.
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor
.idea/
.vscode/*
!.vscode/extensions.json
